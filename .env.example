# --- Database (server-only) ---
# Source of truth, matches docker-compose Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_manager?sslmode=disable
# Dedicated test database on the same Postgres. dbmate applies migrations here in
# Vitest globalSetup; the test-Postgres repository test only runs when this is set.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_manager_test?sslmode=disable

# --- Electric sync (browser-readable) ---
# VITE_ prefix exposes it to the browser, which subscribes to the Electric HTTP
# shape directly (local-only, no shape auth). Maps to the docker-compose port.
VITE_ELECTRIC_URL=http://localhost:3001

# --- LLM / source API keys (server-only) ---
ANTHROPIC_API_KEY=
YOUTUBE_API_KEY=

# --- Obsidian vault ---
# Absolute path to the vault the tool reads the Voice from and writes Drafts into.
OBSIDIAN_VAULT_PATH=
